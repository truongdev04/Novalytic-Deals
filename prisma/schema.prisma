// Prisma schema for NovalyticDeals backend.
// Mirrors the domain model in CLAUDE.md and the shapes already used by
// types/*.ts + data/*.json, so lib/data/* can swap its internals without
// changing any exported function signature.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StoreRegion {
  US
  EU
  GLOBAL
}

enum CouponType {
  CODE
  DEAL
  CASHBACK
  FREESHIP
  BOGO
}

enum DiscountType {
  PERCENT
  AMOUNT
  OTHER
}

enum AdminRole {
  ADMIN
  EDITOR
}

enum AdminUserStatus {
  ACTIVE
  INACTIVE
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RedirectType {
  PERMANENT
  TEMPORARY
}

enum DealType {
  DEAL
  CODE
}

model Store {
  id               String   @id
  slug             String   @unique
  name             String
  logoUrl          String
  bannerUrl        String?
  website          String
  description      String
  aboutStore       String   @default("")
  howToApply       String?
  rating           Float    @default(0)
  ratingCount      Int      @default(0)
  region           StoreRegion
  affiliateNetwork String
  isFeatured       Boolean  @default(false)
  isPin            Boolean  @default(false)
  isActive         Boolean  @default(true)
  // Rolling monthly click counters (lib/content/popularStoresRefresh.ts) — currentMonthClicks
  // increments on every /go/[couponId] redirect, lastMonthClicks is its frozen value from the
  // previous UTC month (rolled over lazily when Auto Popular is enabled). Drive Popular Stores
  // ranking; no lifetime total is kept anymore (superseded the old single clickCount column).
  currentMonthClicks Int    @default(0)
  lastMonthClicks    Int    @default(0)
  seo              Json
  faq              Json
  categoryIds      String[]
  eventId          String?
  // Monthly-frozen SEO title/description discount snapshot (lib/content/storeSeoSnapshot.ts) —
  // seoDiscountSnapshot is the formatted value (e.g. "20%") or null when the store currently has
  // no qualifying coupon (fallback template used instead); seoDiscountSnapshotPeriod is the UTC
  // "YYYY-MM" key it was computed for. Recomputed lazily on the first store-page render of a new
  // period, not admin-editable.
  seoDiscountSnapshot       String?
  seoDiscountSnapshotPeriod String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  event   Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  coupons Coupon[]
  deals   Deal[]
  reviews Review[]

  @@index([isFeatured])
  @@index([isPin])
  @@index([isActive])
  @@index([eventId])
  @@index([categoryIds], type: Gin)
  @@map("stores")
}

model Category {
  id          String   @id
  slug        String   @unique
  name        String
  description String
  iconName    String
  iconImageUrl String?
  isFeatured  Boolean  @default(false)
  seo         Json
  faq         Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")

  blogPosts BlogPost[]
  deals     Deal[]

  @@index([parentId])
  @@index([isFeatured])
  @@map("categories")
}

model Coupon {
  id             String       @id
  slug           String       @unique
  storeId        String
  store          Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title          String
  description    String
  type           CouponType
  code           String?
  discountType   DiscountType
  discountValue  Float
  currency       String
  affiliateUrl   String
  exclusive      Boolean      @default(false)
  verified       Boolean      @default(false)
  verifiedAt     DateTime?
  terms          String
  startsAt       DateTime
  expiresAt      DateTime?
  usageCount     Int          @default(0)
  upvotes        Int          @default(0)
  downvotes      Int          @default(0)
  isFeatured     Boolean      @default(false)
  isTrending     Boolean      @default(false)
  isActive       Boolean      @default(true)
  // Rolling 8-hour click counters (lib/content/couponsRefresh.ts) — currentHourClicks
  // increments on every affiliate-redirect click (app/go/[couponId]/route.ts),
  // lastHourClicks is its frozen value from the last Auto Coupon rollover.
  currentHourClicks Int       @default(0)
  lastHourClicks    Int       @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  eventCoupons EventCoupon[]

  @@index([storeId])
  @@index([expiresAt])
  @@index([isFeatured])
  @@index([isTrending])
  @@index([isActive])
  @@map("coupons")
}

model Deal {
  id            String    @id
  slug          String    @unique
  storeId       String
  store         Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name          String
  type          DealType
  code          String?
  eventId       String?
  event         Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  originalPrice Float?
  price         Float
  offer         String?
  url           String
  imageUrl      String
  description   String?
  isFeatured    Boolean   @default(false)
  isActive      Boolean   @default(true)
  // Rolling 8-hour click counters (lib/content/dealsRefresh.ts) — currentHourClicks
  // increments on every "Get Deal"/"Show Code" click (app/api/deals/[id]/click),
  // lastHourClicks is its frozen value from the last Auto Deal rollover.
  currentHourClicks Int   @default(0)
  lastHourClicks    Int   @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([storeId])
  @@index([eventId])
  @@index([categoryId])
  @@index([isFeatured])
  @@index([isActive])
  @@map("deals")
}

model BlogPost {
  id              String     @id
  slug            String     @unique
  title           String
  excerpt         String
  coverImage      String
  authorName      String
  authorAvatarUrl String?
  categoryId      String?
  category        Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  topicId         String?
  topic           BlogTopic? @relation(fields: [topicId], references: [id], onDelete: SetNull)
  body            String     @db.Text
  readingMinutes  Int
  publishedAt     DateTime
  seo             Json
  isFeatured      Boolean    @default(false)
  isFirst         Boolean    @default(false)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([categoryId])
  @@index([topicId])
  @@index([publishedAt])
  @@index([isActive])
  @@index([isFeatured])
  @@map("blog_posts")
}

model BlogTopic {
  id          String   @id
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts BlogPost[]

  @@map("blog_topics")
}

model Event {
  id           String    @id
  slug         String    @unique
  name         String
  iconName     String
  iconImageUrl String?
  description  String
  bannerUrl    String?
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  stores       Store[]
  deals        Deal[]
  eventCoupons EventCoupon[]

  @@map("events")
}

// Join table for curated coupons on an event. Both FKs cascade on delete so
// removing a coupon (directly, or via its store cascading) or an event
// automatically drops the association — no denormalized array to clean up
// by hand (see the previous String[] approach this replaces).
model EventCoupon {
  eventId   String
  couponId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@id([eventId, couponId])
  @@index([couponId])
  @@map("event_coupons")
}

model Review {
  id         String   @id @default(cuid())
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId     String?
  authorName String
  rating     Int
  title      String
  body       String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([storeId])
  @@index([isApproved])
  @@map("reviews")
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  confirmedAt    DateTime?
  unsubscribedAt DateTime?
  source         String?
  tags           String[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("newsletter_subscribers")
}

model SubmittedCoupon {
  id              String           @id @default(cuid())
  storeName       String
  websiteUrl      String   @default("")
  code            String?
  discountUnit    String   @default("%")
  discountValue   Float    @default(0)
  description     String
  expiresAt       DateTime?
  submitterEmail  String
  status          SubmissionStatus @default(PENDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@map("submitted_coupons")
}

model SiteSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  hashedPassword String?
  oauthId        String?
  role           AdminRole @default(EDITOR)
  status         AdminUserStatus @default(ACTIVE)
  fullName       String?
  avatarUrl      String?
  phone          String?
  permissions    String[]  @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("users")
}

model RedirectRule {
  id          String       @id @default(cuid())
  source      String       @unique
  destination String
  type        RedirectType @default(PERMANENT)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("redirect_rules")
}
